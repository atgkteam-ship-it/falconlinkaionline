{
  "systemSetup": [],
  "templateName": "custom",
  "projectDependencies": [
    {
      "name": "Install Dependencies",
      "command": "npm install"
    }
  ],
  "codeChecks": [
    {
      "name": "Lint",
      "command": "npm run lint"
    }
  ],
  "buildSteps": [
    {
      "name": "Build Project",
      "command": "npm run build"
    }
  ],
  "runStep": [
    {
      "name": "Run Dev Server",
      "command": "npm run dev -- --port 3000 --host",
      "port": "3000"
    }
  ],
  "deploySteps": [
    {
      "name": "Build for Deploy",
      "command": "npm run build"
    }
  ],
  "cleanupFiles": [
    "node_modules",
    ".tanstack",
    "dist",
    "build"
  ],
  "packageManager": "npm",
  "envPaths": [
    {
      "name": "default",
      "path": ".env"
    }
  ]
}
